# 資料庫連線
DATABASE_URL=postgresql+psycopg2://ledger_user:CHANGE_ME@localhost:5432/ledger_db

# JWT 設定
SECRET_KEY=CHANGE_ME_TO_A_LONG_RANDOM_STRING
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# CORS(部署後改成實際前端網域,例如 https://ledger.example.com)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
